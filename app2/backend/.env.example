# ── ShopApp Environment Configuration ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The Go app reads these from the environment — set them before running.
#
# Linux/macOS:
#   export $(grep -v '^#' .env | xargs) && go run main.go
#
# Windows (PowerShell):
#   Get-Content .env | Where-Object {$_ -notmatch '^#'} | ForEach-Object {
#     $kv = $_ -split '=', 2; [System.Environment]::SetEnvironmentVariable($kv[0], $kv[1])
#   }
#   go run main.go

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── MySQL Database ────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=shopapp

# ── JWT ───────────────────────────────────────────────────────────────────────
# Use a long, random string in production!
JWT_SECRET=change-me-to-a-long-random-secret-in-production
